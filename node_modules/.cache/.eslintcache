          </div>\r\n                <aside className=\"my-info\">\r\n                    <p>Hello! My name is Devon Eadie and i am a Full Stack Web Developer.</p>\r\n                </aside>\r\n                <div className=\"skills-info\">\r\n                    <header className=\"my-skills-header\">My Skills</header>\r\n                    <ol className=\"skills-list\">\r\n                    <li>Javascript</li>\r\n                    <li>CSS</li>\r\n                    <li>HTML</li>\r\n                    <li>React</li>\r\n                    <li>MongoDB</li>\r\n                    <li>Mongoose</li>\r\n                    <li>MySQL</li>\r\n                    <li>Git</li>\r\n                    <li>Responsive Design</li>\r\n                    <li>Bulma</li>\r\n                    <li>Bootstrap</li>\r\n                    <li>SEO</li>\r\n                    </ol>\r\n                </div>\r\n                <div className=\"im-from-wrapper\">\r\n                    <header className=\"location-info\">My Home?</header>\r\n                    <p className=\"info-p\">I am from the beautiful city of Vancouver B.C!</p>\r\n                    <img className=\"vancouver\"\r\n                        src={vancouverphoto}\r\n                        alt=\"vancouver\"></img>\r\n                </div>\r\n            </div>\r\n    )\r\n};\r\n\r\nexport default Aboutme;","S:\\Projects\\Programming\\2023\\react-portfolio\\src\\components\\Navigation.js",[],[],"S:\\Projects\\Programming\\2023\\react-portfolio\\src\\pages\\Contact.js",[],[],"S:\\Projects\\Programming\\2023\\react-portfolio\\src\\pages\\Resume.js",[],[],{"ruleId":"50","severity":1,"message":"51","line":14,"column":21,"nodeType":"52","endLine":16,"endColumn":42},"jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","JSXOpeningElement"]